# Public site URL (no trailing slash), used for canonicals, JSON-LD, and logo in emails.
VITE_SITE_ORIGIN=https://www.hotsites.nl

# --- EmailJS (contact form) -------------------------------------------------
# 1. https://www.emailjs.com → Email Service + Public Key (Account → API keys).
# 2. One Email Template used twice per submit (visitor confirmation + team notification).
#    In EmailJS, set:
#      To Email: {{to_email}}
#      Subject: {{subject}}
#      Content type: HTML (if available).
#      Body: {{{message}}}  ← triple braces so the app’s full HTML renders (not escaped).
#    The app sends only: to_email, subject, message (HTML), plus reply_to / from_name on the admin send.
# 3. Copy to `.env`, fill values, restart `npm run dev`; set the same vars on your host.
#
# HTTP 412 from api.emailjs.com → reconnect the mail service in the EmailJS dashboard
# (Gmail: enable “Send email on your behalf”). For local UI testing without EmailJS:
# VITE_MOCK_EMAILJS=true   # dev only; skips send, shows success
# -----------------------------------------------------------------------------
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_PUBLIC_KEY=
VITE_EMAILJS_USER_TEMPLATE_ID=
