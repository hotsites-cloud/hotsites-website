# Public site URL (no trailing slash), used for canonicals, JSON-LD, and logo in emails.
VITE_SITE_ORIGIN=https://www.hotsites.nl

# EmailJS (contact form). Set in your static host’s build environment.
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_PUBLIC_KEY=

# Required: (1) Dutch confirmation to the visitor, To Email: {{visitor_email}}
# (2) Admin inbox, set “To Email” to sam@sambalerbij.nl in the EmailJS template.
VITE_EMAILJS_USER_TEMPLATE_ID=
VITE_EMAILJS_ADMIN_TEMPLATE_ID=
