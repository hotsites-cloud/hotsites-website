# Public site URL (no trailing slash) — used for canonicals, JSON-LD, and logo in emails.
VITE_SITE_ORIGIN=https://www.hotsites.nl

# EmailJS (contact form). Set in your static host’s build environment.
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_PUBLIC_KEY=

# Two templates: (1) confirmation to the visitor with logo, (2) notification to your team.
# In the admin template, set “To Email” to sam@sambalerbij.nl (or your address).
VITE_EMAILJS_USER_TEMPLATE_ID=
VITE_EMAILJS_ADMIN_TEMPLATE_ID=

# Legacy: single template only (visitor + team in one flow). Omit user/admin IDs to use this.
# VITE_EMAILJS_TEMPLATE_ID=
